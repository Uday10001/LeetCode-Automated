# ─── LeetCode Automator — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values

# Required: Your OpenAI API Key
OPENAI_API_KEY= your-api-key
# Optional: Path to persistent Chrome profile (for auto-submit login)
# Defaults to ~/.leetcode_chrome_profile if not set
CHROME_PROFILE_DIR=/path/to/your/chrome/profile

# Optional: Server settings
HOST=0.0.0.0
PORT=8000
